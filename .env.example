# Frontend build-time variable for Clerk (required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Server-side Clerk secret (required)
CLERK_SECRET_KEY=sk_test_xxx

# Comma-separated Clerk user ids that should have admin rights
APP_ADMIN_USER_IDS=user_xxx

# Persisted workspace storage path
DATA_DIR=/data

# Optional explicit port override
PORT=8080
