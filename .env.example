# CGP CRM – Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus.

# OpenAI API Key für KI-Notiz-Zusammenfassung
# Erhalte deinen Key unter: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Calendar OAuth2 (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GCAL_REFRESH_TOKEN=

# Server
PORT=5000
NODE_ENV=development
