
import { createContext, useCallback, useContext, useEffect, useMemo, useState, type ReactNode } from 'react';
import { useAuth, useUser } from '@clerk/react';
import { getInitials, team as defaultTeam, type ActivityItem, type Customer, type CustomerStatus, type NoteType, type ServiceEvent, type ServiceStatus, type Task, type TaskPriority, type TaskStatus, type TeamMember } from './store';

export type ThemeMode = 'dark' | 'light' | 'system';
export type Page = 'dashboard' | 'kunden' | 'aufgaben' | 'einsaetze' | 'kalender' | 'ops' | 'einstellungen';
export type AppRole = 'admin' | 'manager' | 'dispatcher' | 'techniker' | 'anonymous';

interface SettingsState {
  profileName: string;
  company: string;
  email: string;
  phone: string;
  theme: ThemeMode;
  compactTables: boolean;
  emailUpdates: boolean;
  pushAlerts: boolean;
}

interface UiFeedback {
  type: 'success' | 'error';
  message: string;
}

interface ViewerState {
  userId: string | null;
  role: AppRole;
  name: string;
  email: string;
}

interface SystemHealthState {
  ok: boolean;
  storage: string;
  auditStorage?: string;
  auditMode?: string;
  auditCount?: number | null;
  version: string;
  startedAt: string;
  now: string;
  message?: string;
}

interface ApiLogEntry {
  id: string;
  level: 'info' | 'warn' | 'error';
  code: string;
  message: string;
  meta: Record<string, unknown>;
  createdAt: string;
}

interface AppStoreContextValue {
  customers: Customer[];
  serviceEvents: ServiceEvent[];
  team: TeamMember[];
  settings: SettingsState;
  viewer: ViewerState;
  systemHealth: SystemHealthState | null;
  isBooting: boolean;
  saveState: 'idle' | 'saving' | 'saved';
  feedback: UiFeedback | null;
  activity: ActivityItem[];
  overdueTasks: Task[];
  todayServices: ServiceEvent[];
  openTasks: Task[];
  kpi: {
    activeCustomers: number;
    riskCustomers: number;
    openTasks: number;
    urgentTasks: number;
    todayServices: number;
    waitingCustomers: number;
  };
  clearFeedback: () => void;
  setFeedback: (value: UiFeedback | null) => void;
  fetchAudit: (query: { entityType?: 'customer' | 'task' | 'service'; entityId?: string; customerId?: string; limit?: number }) => Promise<ActivityItem[]>;
  fetchLogs: (query?: { level?: 'info' | 'warn' | 'error'; limit?: number }) => Promise<ApiLogEntry[]>;
  updateSettings: (patch: Partial<SettingsState>) => Promise<void>;
  addCustomer: (payload: { name: string; city: string; email: string; address?: string; zip?: string; phone?: string; status?: CustomerStatus; priority?: TaskPriority; contactName?: string; contactRole?: string; contactPhone?: string; contactEmail?: string; tags?: string[] }) => Promise<void>;
  updateCustomerStatus: (customerId: string, status: CustomerStatus) => Promise<void>;
  addCustomerTag: (customerId: string, tag: string) => Promise<void>;
  addCustomerNote: (customerId: string, payload: { content: string; type: NoteType; pinned?: boolean }) => Promise<void>;
  addTask: (payload: { customerId: string; title: string; description?: string; priority?: TaskPriority; dueDate?: string; assignee?: string }) => Promise<void>;
  updateTask: (taskId: string, patch: Partial<Pick<Task, 'title' | 'description' | 'priority' | 'dueDate' | 'assignee' | 'status'>>) => Promise<void>;
  updateTaskStatus: (taskId: string, status?: TaskStatus) => Promise<void>;
  addServiceEvent: (payload: { customerId: string; title: string; date: string; startTime?: string; endTime?: string; assignee?: string; description?: string }) => Promise<void>;
  updateService: (eventId: string, patch: Partial<Pick<ServiceEvent, 'title' | 'description' | 'date' | 'startTime' | 'endTime' | 'assignee' | 'status'>>) => Promise<void>;
  updateServiceStatus: (eventId: string, status?: ServiceStatus) => Promise<void>;
  addServiceNote: (eventId: string, note: string) => Promise<void>;
  resetDemoData: () => Promise<void>;
  reloadWorkspace: () => Promise<void>;
}

const API_BASE = import.meta.env.VITE_API_BASE_URL || '';
const AppStoreContext = createContext<AppStoreContextValue | null>(null);

const defaultSettings: SettingsState = {
  profileName: 'Lars Herzer',
  company: 'CGP Solutions GmbH',
  email: 'lars@cgp.de',
  phone: '+49 89 1234567',
  theme: 'dark',
  compactTables: false,
  emailUpdates: true,
  pushAlerts: true,
};

function apiUrl(path: string) {
  return `${API_BASE}${path}`;
}

export function AppStoreProvider({ children }: { children: ReactNode }) {
  const { getToken, isLoaded } = useAuth();
  const { user } = useUser();
  const [customers, setCustomers] = useState<Customer[]>([]);
  const [serviceEvents, setServiceEvents] = useState<ServiceEvent[]>([]);
  const [team, setTeam] = useState<TeamMember[]>(defaultTeam);
  const [settings, setSettings] = useState<SettingsState>(defaultSettings);
  const [activity, setActivity] = useState<ActivityItem[]>([]);
  const [viewer, setViewer] = useState<ViewerState>({ userId: null, role: 'anonymous', name: 'Gast', email: '' });
  const [systemHealth, setSystemHealth] = useState<SystemHealthState | null>(null);
  const [isBooting, setIsBooting] = useState(true);
  const [saveState, setSaveState] = useState<'idle' | 'saving' | 'saved'>('idle');
  const [feedback, setFeedback] = useState<UiFeedback | null>(null);

  const applySnapshot = useCallback((snapshot: any) => {
    setCustomers(snapshot.customers || []);
    setServiceEvents(snapshot.serviceEvents || []);
    setTeam(snapshot.team || defaultTeam);
    setSettings(snapshot.settings || defaultSettings);
    setActivity(snapshot.activity || []);
    setViewer(snapshot.viewer || { userId: null, role: 'anonymous', name: 'Gast', email: '' });
  }, []);

  const request = useCallback(async (path: string, init: RequestInit = {}) => {
    const token = await getToken();
    const response = await fetch(apiUrl(path), {
      ...init,
      headers: {
        'Content-Type': 'application/json',
        ...(token ? { Authorization: `Bearer ${token}` } : {}),
        ...(init.headers || {}),
      },
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) {
      throw new Error(data.error || 'Anfrage fehlgeschlagen.');
    }
    return data;
  }, [getToken]);

  const loadHealth = useCallback(async () => {
    try {
      const response = await fetch(apiUrl('/api/health'));
      const data = await response.json();
      setSystemHealth({
        ok: Boolean(data.ok),
        storage: data.storage?.storage || data.storage || 'unknown',
        auditStorage: data.audit?.storage || data.storage?.auditStorage || undefined,
        auditMode: data.audit?.mode || data.storage?.activityMode || undefined,
        auditCount: data.audit?.count ?? data.storage?.activityCount ?? null,
        version: data.version || 'unknown',
        startedAt: data.startedAt || '',
        now: data.now || '',
        message: data.storage?.message || undefined,
      });
    } catch {
      setSystemHealth({ ok: false, storage: 'unknown', version: 'unknown', startedAt: '', now: '', message: 'Healthcheck nicht erreichbar.' });
    }
  }, []);

  const reloadWorkspace = useCallback(async () => {
    if (!isLoaded) return;
    setIsBooting(true);
    try {
      await loadHealth();
      const data = await request('/api/bootstrap');
      applySnapshot(data);
    } catch (error) {
      setFeedback({ type: 'error', message: error instanceof Error ? error.message : 'Workspace konnte nicht geladen werden.' });
    } finally {
      setIsBooting(false);
    }
  }, [applySnapshot, isLoaded, request, loadHealth]);

  useEffect(() => {
    if (!isLoaded) return;
    reloadWorkspace();
  }, [isLoaded, reloadWorkspace]);

  useEffect(() => {
    document.documentElement.dataset.theme = settings.theme;
  }, [settings.theme]);

  useEffect(() => {
    if (saveState !== 'saved') return;
    const timeout = window.setTimeout(() => setSaveState('idle'), 1200);
    return () => window.clearTimeout(timeout);
  }, [saveState]);

  const runAction = useCallback(async (action: string, payload: Record<string, unknown>, successMessage?: string) => {
    setSaveState('saving');
    try {
      const data = await request('/api/actions', { method: 'POST', body: JSON.stringify({ action, payload }) });
      applySnapshot(data);
      setSaveState('saved');
      if (successMessage) setFeedback({ type: 'success', message: successMessage });
    } catch (error) {
      setSaveState('idle');
      setFeedback({ type: 'error', message: error instanceof Error ? error.message : 'Aktion fehlgeschlagen.' });
      throw error;
    }
  }, [applySnapshot, request]);

  const today = new Date().toISOString().slice(0, 10);
  const openTasks = useMemo(() => customers.flatMap((customer) => customer.tasks).filter((task) => task.status !== 'erledigt'), [customers]);
  const overdueTasks = useMemo(() => openTasks.filter((task) => task.dueDate < today), [openTasks, today]);
  const todayServices = useMemo(() => serviceEvents.filter((event) => event.date === today && event.status !== 'abgesagt'), [serviceEvents, today]);

  const value: AppStoreContextValue = {
    customers,
    serviceEvents,
    team,
    settings,
    viewer,
    systemHealth,
    isBooting,
    saveState,
    feedback,
    activity,
    overdueTasks,
    todayServices,
    openTasks,
    kpi: {
      activeCustomers: customers.filter((customer) => customer.status === 'aktiv').length,
      riskCustomers: customers.filter((customer) => customer.status === 'risiko').length,
      openTasks: openTasks.length,
      urgentTasks: openTasks.filter((task) => task.priority === 'dringend').length,
      todayServices: todayServices.length,
      waitingCustomers: customers.filter((customer) => customer.status === 'wartet').length,
    },
    clearFeedback: () => setFeedback(null),
    setFeedback,
    fetchAudit: async (query) => {
      const params = new URLSearchParams();
      if (query.entityType) params.set('entityType', query.entityType);
      if (query.entityId) params.set('entityId', query.entityId);
      if (query.customerId) params.set('customerId', query.customerId);
      if (query.limit) params.set('limit', String(query.limit));
      const data = await request(`/api/audit${params.size ? `?${params.toString()}` : ''}`);
      return data.items || [];
    },
    fetchLogs: async (query = {}) => {
      const params = new URLSearchParams();
      if (query.level) params.set('level', query.level);
      if (query.limit) params.set('limit', String(query.limit));
      const data = await request(`/api/logs${params.size ? `?${params.toString()}` : ''}`);
      return data.items || [];
    },
    reloadWorkspace,
    updateSettings: async (patch) => runAction('updateSettings', patch, 'Einstellungen wurden gespeichert.'),
    addCustomer: async (payload) => runAction('addCustomer', payload, 'Kunde wurde angelegt.'),
    updateCustomerStatus: async (customerId, status) => runAction('updateCustomerStatus', { customerId, status }, 'Kundenstatus wurde geändert.'),
    addCustomerTag: async (customerId, tag) => runAction('addCustomerTag', { customerId, tag }, 'Tag wurde ergänzt.'),
    addCustomerNote: async (customerId, payload) => runAction('addCustomerNote', { customerId, ...payload }, 'Notiz wurde gespeichert.'),
    addTask: async (payload) => runAction('addTask', payload, 'Aufgabe wurde angelegt.'),
    updateTask: async (taskId, patch) => runAction('updateTask', { taskId, patch }, 'Aufgabe wurde aktualisiert.'),
    updateTaskStatus: async (taskId, status) => runAction('updateTaskStatus', { taskId, status }, 'Aufgabenstatus wurde geändert.'),
    addServiceEvent: async (payload) => runAction('addServiceEvent', payload, 'Einsatz wurde geplant.'),
    updateService: async (eventId, patch) => runAction('updateService', { eventId, patch }, 'Einsatz wurde aktualisiert.'),
    updateServiceStatus: async (eventId, status) => runAction('updateServiceStatus', { eventId, status }, 'Einsatzstatus wurde geändert.'),
    addServiceNote: async (eventId, note) => runAction('addServiceNote', { eventId, note }, 'Einsatznotiz wurde ergänzt.'),
    resetDemoData: async () => runAction('resetDemoData', {}, 'Demo-Daten wurden zurückgesetzt.'),
  };

  return <AppStoreContext.Provider value={value}>{children}</AppStoreContext.Provider>;
}

export function useAppStore() {
  const context = useContext(AppStoreContext);
  if (!context) throw new Error('useAppStore must be used within AppStoreProvider');
  return context;
}

export { getInitials };
